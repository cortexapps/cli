# Cortex API key. Get from Cortex Settings > API Keys.
# Needs "Run workflows" and "View workflow runs" permissions for functional tests.
CORTEX_API_KEY=

# Cortex API base URL. Defaults to Cortex Cloud; override for self-hosted instances.
CORTEX_BASE_URL=https://api.getcortexapp.com

# GitHub org dedicated to functional tests. Tests create/delete ephemeral repos here
# with a "cli-functional-test-" prefix. The org must have a custom property called
# "cortex-cli-functional-test" as a safety check to prevent accidental use of production orgs.
GITHUB_TEST_ORG=

# GitHub Personal Access Token for functional test API calls.
# Create at GitHub > Settings > Developer settings > Personal access tokens.
# Required scopes: repo, admin:org, delete_repo.
GITHUB_TOKEN=

# GitHub username for testing org/team membership operations.
# Must NOT be an org owner — tests add/remove this user from orgs and teams.
GITHUB_TEST_USERNAME=

# Alias of the Cortex GitHub integration. Found in Cortex Settings > Integrations > GitHub.
# Used to substitute into workflow YAML templates. If not set, GitHub workflow tests are skipped.
GITHUB_INTEGRATION_ALIAS=

# GitLab personal access token for functional test API calls.
# Create at GitLab > User Settings > Access tokens. Needs API and project admin scopes.
GITLAB_TOKEN=

# Alias of the Cortex GitLab integration. Found in Cortex Settings > Integrations > GitLab.
# Used to substitute into workflow YAML templates. If not set, GitLab workflow tests are skipped.
GITLAB_INTEGRATION_ALIAS=

# ---------------------------------------------------------------------------
# K8s agent tests
# ---------------------------------------------------------------------------

# GitHub username for GHCR authentication. The k8s-agent image is pulled from
# ghcr.io/cortexapps/k8s-agent. Uses GITHUB_TOKEN (above) for the password.
GH_USER=

# ---------------------------------------------------------------------------
# Playwright UI tests
# ---------------------------------------------------------------------------

# Cortex web app URL. Defaults to Cortex Cloud.
CORTEX_APP_URL=https://app.getcortexapp.com

# Cortex tenant code. Found in your Cortex URL: app.getcortexapp.com/<tenant-code>
CORTEX_TENANT_CODE=

# Google account credentials for SSO login.
# The Playwright tests automate Google OAuth + TOTP MFA to authenticate.
GOOGLE_EMAIL=
GOOGLE_PASSWORD=

# Google Authenticator TOTP URI. Used to generate MFA codes automatically.
# Format: otpauth://totp/Google:<email>?secret=<secret>&issuer=Google
# Get this when setting up 2FA — choose "Can't scan it?" to see the secret.
GOOGLE_TOTP_URI=

# ---------------------------------------------------------------------------
# Workday integration tests
# ---------------------------------------------------------------------------

# Workday service account credentials for the ownership report API.
WORKDAY_USERNAME=
WORKDAY_PASSWORD=

# Workday custom report URL that returns ownership data.
WORKDAY_OWNERSHIP_REPORT_URL=

# ---------------------------------------------------------------------------
# Axon relay
# ---------------------------------------------------------------------------

# Uses GITHUB_TOKEN and GITLAB_TOKEN from above.

# --- Jira (optional) ---
# JIRA_API defaults to https://cortex1.atlassian.net in compose.yaml.
JIRA_API=
JIRA_TOKEN=

# --- Bitbucket (optional) ---
# BITBUCKET_API defaults to https://api.bitbucket.org in compose.yaml.
BITBUCKET_API=
BITBUCKET_USERNAME=
BITBUCKET_PASSWORD=

# --- SonarQube (optional) ---
SONAR_TOKEN=

# --- Jenkins (auto-generated by `just axon-test`) ---
# These are written automatically on first run. Do not set manually.
JENKINS_USERNAME=
JENKINS_PASSWORD=
# Base64-encoded admin:<api-token> for the relay Authorization header
AUTHORIZATION_TOKEN=

# --- Prometheus (optional) ---
# Defaults to http://host.docker.internal:9090 (local prometheus-setup).
PROMETHEUS_API=
PROMETHEUS_USERNAME=
PROMETHEUS_PASSWORD=

# ---------------------------------------------------------------------------
# SKE (Syntasso Kratix Enterprise)
# ---------------------------------------------------------------------------

# Syntasso license token. This ghp_-prefixed GitHub PAT is used for both
# the SKE license and pulling images from ghcr.io/syntasso.
SKE_LICENSE_TOKEN=

# SKE version to install (e.g., v0.99.0). Check Syntasso docs for latest.
SKE_VERSION=v0.99.0
