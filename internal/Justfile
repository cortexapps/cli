# Start axon relay containers for configured integrations
axon-setup: (_ensure-env "CORTEX_API_KEY|Cortex API key|Get from Cortex Settings > API Keys.")
    #!/usr/bin/env bash
    set -euo pipefail

    services=()

    [ -n "${GITHUB_TOKEN:-}" ] && services+=(github)
    [ -n "${GITLAB_TOKEN:-}" ] && services+=(gitlab)
    [ -n "${JIRA_TOKEN:-}" ] && services+=(jira)
    [ -n "${BITBUCKET_USERNAME:-}" ] && [ -n "${BITBUCKET_PASSWORD:-}" ] && services+=(bitbucket)
    [ -n "${SONAR_TOKEN:-}" ] && services+=(sonarqube)
    [ -n "${PROMETHEUS_API:-}" ] && services+=(prometheus)

    if [ ${#services[@]} -eq 0 ]; then
        echo "No integrations configured. Set variables in .env for the integrations you want:"
        echo "  - GitHub:     GITHUB_TOKEN"
        echo "  - GitLab:     GITLAB_TOKEN"
        echo "  - Jira:       JIRA_TOKEN"
        echo "  - Bitbucket:  BITBUCKET_USERNAME + BITBUCKET_PASSWORD"
        echo "  - SonarQube:  SONAR_TOKEN"
        echo "  - Prometheus: PROMETHEUS_API"
        exit 0
    fi

    echo "Starting axon relay for: ${services[*]}"
    docker compose -f axon/compose.yaml up -d "${services[@]}"
    echo "Done. Running containers:"
    docker compose -f axon/compose.yaml ps

# Show status of axon relay containers
axon-status:
    docker compose -f axon/compose.yaml ps -a

# Stop all axon relay containers
axon-stop:
    docker compose -f axon/compose.yaml down

# ---------------------------------------------------------------------------
# Axon + Jenkins test
# ---------------------------------------------------------------------------

# Set up Jenkins + relay, create pipeline job, push workflow to Cortex
axon-test: (_ensure-env "CORTEX_API_KEY|Cortex API key|Get from Cortex Settings > API Keys.")
    #!/usr/bin/env bash
    set -euo pipefail

    # 1. Build and start Jenkins
    echo "Starting Jenkins..."
    docker compose -f axon/compose.yaml up -d --build jenkins

    # 2. Wait for Jenkins API to be ready
    echo "Waiting for Jenkins to be ready..."
    for i in $(seq 1 90); do
        if curl -sf -u admin:admin http://localhost:9090/api/json > /dev/null 2>&1; then
            echo "Jenkins is ready."
            break
        fi
        if [ "$i" -eq 90 ]; then
            echo "Jenkins did not become ready within 180s"
            echo "Check: docker compose -f axon/compose.yaml logs jenkins"
            exit 1
        fi
        sleep 2
    done

    # 3. Fetch CSRF crumb (save session cookie for subsequent requests)
    COOKIE_JAR=$(mktemp)
    trap "rm -f $COOKIE_JAR" EXIT
    CRUMB_JSON=$(curl -sf -u admin:admin -c "$COOKIE_JAR" http://localhost:9090/crumbIssuer/api/json)
    CRUMB_FIELD=$(echo "$CRUMB_JSON" | jq -r '.crumbRequestField')
    CRUMB_VALUE=$(echo "$CRUMB_JSON" | jq -r '.crumb')

    # 4. Create the pipeline job (ignore 400 if it already exists)
    echo "Creating axon-demo pipeline job..."
    HTTP_CODE=$(curl -s -o /dev/null -w "%{http_code}" -u admin:admin \
        -b "$COOKIE_JAR" \
        -H "$CRUMB_FIELD: $CRUMB_VALUE" \
        -X POST "http://localhost:9090/createItem?name=axon-demo" \
        -H "Content-Type: application/xml" \
        --data-binary @axon/jenkins/job-config.xml)
    if [ "$HTTP_CODE" = "200" ]; then
        echo "  Created axon-demo job."
    elif [ "$HTTP_CODE" = "400" ]; then
        echo "  axon-demo job already exists."
    else
        echo "  Warning: unexpected HTTP $HTTP_CODE creating job."
    fi

    # 5. Generate Jenkins API token and write to .env
    if grep -q "^JENKINS_PASSWORD=" .env 2>/dev/null; then
        echo "JENKINS_PASSWORD already set in .env, skipping token generation."
    else
        echo "Generating Jenkins API token..."
        TOKEN_RESPONSE=$(curl -sf -u admin:admin \
            -b "$COOKIE_JAR" \
            -H "$CRUMB_FIELD: $CRUMB_VALUE" \
            -X POST "http://localhost:9090/user/admin/descriptorByName/jenkins.security.ApiTokenProperty/generateNewToken" \
            -d "newTokenName=cortex-relay")
        JENKINS_API_TOKEN=$(echo "$TOKEN_RESPONSE" | jq -r '.data.tokenValue')
        if [ -n "$JENKINS_API_TOKEN" ] && [ "$JENKINS_API_TOKEN" != "null" ]; then
            echo "JENKINS_USERNAME=admin" >> .env
            echo "JENKINS_PASSWORD=$JENKINS_API_TOKEN" >> .env
            # Base64-encoded credentials for the relay's Authorization header
            AUTH_B64=$(echo -n "admin:$JENKINS_API_TOKEN" | base64)
            echo "AUTHORIZATION_TOKEN=$AUTH_B64" >> .env
            echo "  API token generated and written to .env."
        else
            echo "  Error: failed to generate API token."
            echo "  Response: $TOKEN_RESPONSE"
            exit 1
        fi
    fi

    # 6. Start the jenkins-relay
    echo "Starting jenkins-relay..."
    docker compose -f axon/compose.yaml up -d jenkins-relay

    # 7. Push workflow to Cortex
    echo "Pushing workflow to Cortex..."
    {{cortex_cli}} workflows create -f axon/workflow-jenkins.yaml 2>/dev/null || \
        echo "  Workflow may already exist."

    echo ""
    echo "Setup complete."
    echo "  Jenkins UI: http://localhost:9090  (admin/admin)"
    echo "  Workflow:   'Jenkins via Axon Relay' — run from Cortex UI"

# Follow Jenkins relay logs (Ctrl+C to stop)
axon-test-logs:
    docker compose -f axon/compose.yaml logs -f jenkins-relay

# Tear down Jenkins + relay
axon-test-stop:
    docker compose -f axon/compose.yaml down jenkins jenkins-relay
    docker volume rm -f axon_jenkins_home 2>/dev/null || true

# ---------------------------------------------------------------------------
# Axon + Echo server (relay smoke test)
# ---------------------------------------------------------------------------

# Set up echo server + relay, push workflow to Cortex
axon-echo-setup: (_ensure-env "CORTEX_API_KEY|Cortex API key|Get from Cortex Settings > API Keys.")
    #!/usr/bin/env bash
    set -euo pipefail

    echo "Starting echo server + relay..."
    docker compose -f axon/compose.yaml up -d --build echo echo-relay

    echo "Waiting for relay to connect..."
    for i in $(seq 1 30); do
        if docker logs axon-echo-relay 2>&1 | grep -q "started"; then
            echo "Relay connected."
            break
        fi
        if [ "$i" -eq 30 ]; then
            echo "Warning: relay did not start within 30s"
            echo "Check: docker compose -f axon/compose.yaml logs echo-relay"
            exit 1
        fi
        sleep 1
    done

    echo "Pushing workflow to Cortex..."
    {{cortex_cli}} workflows create -f axon/workflow-echo.yaml 2>/dev/null || \
        echo "  Workflow may already exist."

    echo ""
    echo "Setup complete."
    echo "  Echo server: http://localhost:8888"
    echo "  Workflow:    'Echo Server via Axon Relay' — run from Cortex UI or API"

# Follow echo relay logs (Ctrl+C to stop)
axon-echo-logs:
    docker compose -f axon/compose.yaml logs -f echo-relay

# Trigger the echo workflow and wait for completion
axon-echo-test: (_ensure-env "CORTEX_API_KEY|Cortex API key|Get from Cortex Settings > API Keys." "CORTEX_BASE_URL|Cortex API base URL|Defaults to https://api.getcortexapp.com.")
    #!/usr/bin/env bash
    set -euo pipefail

    echo "Triggering echo workflow..."
    RESPONSE=$(curl -sf \
        -H "Authorization: Bearer $CORTEX_API_KEY" \
        -H "Content-Type: application/json" \
        -X POST "${CORTEX_BASE_URL}/api/v1/workflows/echo-axon-relay/runs" \
        -d '{"scope": {"type": "GLOBAL"}}')
    RUN_ID=$(echo "$RESPONSE" | jq -r '.id')
    WF_CID=$(echo "$RESPONSE" | jq -r '.workflow.cid')
    echo "  Run ID: $RUN_ID"

    echo "Waiting for workflow to complete..."
    for i in $(seq 1 30); do
        STATUS=$(curl -sf \
            -H "Authorization: Bearer $CORTEX_API_KEY" \
            "${CORTEX_BASE_URL}/api/v1/workflows/echo-axon-relay/runs/$RUN_ID" | jq -r '.status')
        if [ "$STATUS" = "COMPLETED" ]; then
            echo "Workflow completed successfully!"
            exit 0
        elif [ "$STATUS" = "FAILED" ] || [ "$STATUS" = "TIMED_OUT" ]; then
            echo "Workflow $STATUS"
            exit 1
        fi
        sleep 2
    done
    echo "Warning: workflow did not complete within 60s (status: $STATUS)"

# Tear down echo server + relay
axon-echo-stop:
    docker compose -f axon/compose.yaml down echo echo-relay

